# --- Chain ---
RPC_URL=https://sepolia.rpc.zama.ai
CHAIN_ID=11155111

# --- Keeper identity (must equal the DEX keeper address) ---
KEEPER_PRIVATE_KEY=0x...

# --- Deployed contract ---
DEX_ADDRESS=0x...

# --- Relayer (off-chain public decryption) ---
RELAYER_URL=https://relayer.testnet.zama.org

# --- Lifecycle tuning (keep each tx under the ~20M HCU budget) ---
CLEAR_CHUNK_TICKS=6
SETTLE_CHUNK_ORDERS=4
POLL_INTERVAL_MS=15000

# --- Optional operational persistence ---
DATABASE_URL=postgresql://keeper:keeper@localhost:15432/fba_keeper

# --- Observability ---
METRICS_PORT=9464
LOG_LEVEL=info
