{
  "title": "FBA DEX Keeper",
  "uid": "fba-keeper",
  "schemaVersion": 39,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Current Batch ID",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "fba_current_batch_id" }]
    },
    {
      "type": "stat",
      "title": "Current Batch Status",
      "description": "0=Open 1=Closed 2=Clearing 3=Cleared 4=Settled",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "fba_current_batch_status" }]
    },
    {
      "type": "stat",
      "title": "Batches Settled",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "fba_batches_settled_total" }]
    },
    {
      "type": "stat",
      "title": "Keeper Errors",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "sum(fba_keeper_errors_total)" }]
    },
    {
      "type": "timeseries",
      "title": "Clearing transactions / min",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "rate(fba_clearing_txs_total[5m]) * 60" }]
    },
    {
      "type": "timeseries",
      "title": "Settlement transactions / min",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "expr": "rate(fba_settle_txs_total[5m]) * 60" }]
    },
    {
      "type": "timeseries",
      "title": "Batch lifecycle counters",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        { "expr": "fba_batches_closed_total", "legendFormat": "closed" },
        { "expr": "fba_batches_cleared_total", "legendFormat": "cleared" },
        { "expr": "fba_batches_settled_total", "legendFormat": "settled" }
      ]
    }
  ]
}
